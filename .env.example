# .env.example — Railway'da Environment Variables bo'limiga qo'shing

# Telegram bot tokeni (@BotFather dan oling)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Sizning Telegram ID raqamingiz (admin uchun)
# https://t.me/userinfobot ga yozing va ID ni oling
ADMIN_ID=123456789

# Railway'dagi sayt URL (deploy bo'lgach o'zgartiring)
# Misol: https://dmed-production.up.railway.app
WEB_URL=https://your-app.railway.app

# Telegram Stars narxi (1 Stars ≈ 0.013$)
# 50 Stars ≈ 0.65$
STARS_PRICE=50
